<?xml version="1.0" encoding="utf-8"?>

<Patch>

    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Odyssey</li>
        </mods>
        <match Class="PatchOperationSequence">

            <operations>

                <li Class="PatchOperationReplace">
                    <xpath>*/ThingDef[defName="Turret_AncientArmoredTurret"]/comps/li[@Class="CompProperties_Hackable"]/onlyRemotelyHackable</xpath>
                    <value>
                        <onlyRemotelyHackable>false</onlyRemotelyHackable>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>*/ThingDef[defName="Turret_AncientArmoredTurret"]/comps/li[@Class="CompProperties_Hackable"]/defence</xpath>
                    <value>
                        <defence>15000</defence>
                    </value>
                </li>

            </operations>

        </match>
    </Operation>

</Patch>